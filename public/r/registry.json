{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "form-studio",
  "homepage": "https://github.com/rumeshudash/form-studio",
  "items": [
    {
      "name": "form-renderer",
      "type": "registry:component",
      "title": "Form Renderer",
      "description": "Renders a JSON form schema using @json-render with react-hook-form state management.",
      "dependencies": [
        "@json-render/react",
        "@json-render/core",
        "react-hook-form",
        "zod"
      ],
      "registryDependencies": ["button"],
      "files": [
        {
          "path": "src/registry/form-renderer/index.tsx",
          "type": "registry:component",
          "target": "components/form-renderer/index.tsx"
        },
        {
          "path": "src/registry/form-renderer/types.ts",
          "type": "registry:component",
          "target": "components/form-renderer/types.ts"
        }
      ]
    },
    {
      "name": "form-builder",
      "type": "registry:component",
      "title": "Form Builder",
      "description": "Drag-and-drop form builder that outputs a json-render compatible FormSchema.",
      "dependencies": [
        "@json-render/react",
        "@json-render/core",
        "react-hook-form",
        "zod",
        "@dnd-kit/core",
        "@dnd-kit/sortable",
        "@dnd-kit/utilities"
      ],
      "registryDependencies": [
        "https://rumeshudash.github.io/form-studio/r/form-renderer.json"
      ],
      "files": [
        {
          "path": "src/registry/form-builder/index.tsx",
          "type": "registry:component",
          "target": "components/form-builder/index.tsx"
        },
        {
          "path": "src/registry/form-builder/builder-state.ts",
          "type": "registry:component",
          "target": "components/form-builder/builder-state.ts"
        },
        {
          "path": "src/registry/form-builder/canvas.tsx",
          "type": "registry:component",
          "target": "components/form-builder/canvas.tsx"
        },
        {
          "path": "src/registry/form-builder/field-palette.tsx",
          "type": "registry:component",
          "target": "components/form-builder/field-palette.tsx"
        },
        {
          "path": "src/registry/form-builder/field-config-panel.tsx",
          "type": "registry:component",
          "target": "components/form-builder/field-config-panel.tsx"
        },
        {
          "path": "src/registry/form-builder/field-preview.tsx",
          "type": "registry:component",
          "target": "components/form-builder/field-preview.tsx"
        },
        {
          "path": "src/registry/form-builder/built-in-layout-defs.ts",
          "type": "registry:component",
          "target": "components/form-builder/built-in-layout-defs.ts"
        },
        {
          "path": "src/registry/form-builder/condition-builder.tsx",
          "type": "registry:component",
          "target": "components/form-builder/condition-builder.tsx"
        },
        {
          "path": "src/registry/form-builder/validation-builder.tsx",
          "type": "registry:component",
          "target": "components/form-builder/validation-builder.tsx"
        }
      ]
    },
    {
      "name": "form-builder-with-schema",
      "type": "registry:block",
      "title": "Form Builder with Schema & Preview",
      "description": "Drag-and-drop form builder with a live JSON schema panel (copyable) and form preview.",
      "dependencies": [
        "@json-render/react",
        "@json-render/core",
        "react-hook-form",
        "zod",
        "@dnd-kit/core",
        "@dnd-kit/sortable",
        "@dnd-kit/utilities",
        "shiki"
      ],
      "registryDependencies": [
        "https://rumeshudash.github.io/form-studio/r/form-builder.json",
        "resizable",
        "input",
        "textarea",
        "label",
        "select",
        "checkbox",
        "radio-group",
        "switch",
        "slider"
      ],
      "files": [
        {
          "path": "src/app/blocks/form-builder-with-schema/page.tsx",
          "type": "registry:page",
          "target": "app/form-builder/page.tsx"
        },
        {
          "path": "src/app/blocks/form-builder-with-schema/custom-fields.tsx",
          "type": "registry:component",
          "target": "app/form-builder/custom-fields.tsx"
        },
        {
          "path": "src/app/blocks/form-builder-with-schema/schema-viewer.tsx",
          "type": "registry:component",
          "target": "app/form-builder/schema-viewer.tsx"
        }
      ]
    }
  ]
}
